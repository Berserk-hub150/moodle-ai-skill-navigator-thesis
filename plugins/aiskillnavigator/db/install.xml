<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/aiskillnavigator/db" VERSION="2026060101" COMMENT="XMLDB file for local_aiskillnavigator">
  <TABLES>
    <TABLE NAME="local_aiskillnav_material" COMMENT="Teacher course materials">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="materialtype" TYPE="char" LENGTH="50" NOTNULL="true" DEFAULT="text"/>
        <FIELD NAME="sourcecmid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Course module id when this material was imported from a Moodle activity/resource"/>
        <FIELD NAME="contenthash" TYPE="char" LENGTH="40" NOTNULL="true" DEFAULT="" SEQUENCE="false" COMMENT="SHA1 hash used to detect unchanged duplicated material content"/>
        <FIELD NAME="content" TYPE="text" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="externalaiallowed" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Whether this material can be sent to external AI providers"/>
        <FIELD NAME="aipolicy" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="local_only" SEQUENCE="false" COMMENT="AI usage policy snapshot for this material"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid_ix" UNIQUE="false" FIELDS="courseid"/>
        <INDEX NAME="userid_ix" UNIQUE="false" FIELDS="userid"/>
        <INDEX NAME="materialtype_ix" UNIQUE="false" FIELDS="materialtype"/>
        <INDEX NAME="sourcecmid_ix" UNIQUE="false" FIELDS="sourcecmid"/>
        <INDEX NAME="material_identity_ix" UNIQUE="false" FIELDS="courseid, materialtype, sourcecmid"/>
        <INDEX NAME="contenthash_ix" UNIQUE="false" FIELDS="contenthash"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_aiskillnav_attempt" COMMENT="Student generated quiz attempts">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="topic" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="difficulty" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="medium"/>
        <FIELD NAME="score" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="maxscore" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="percentage" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="quizjson" TYPE="text"/>
        <FIELD NAME="answersjson" TYPE="text"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid_ix" UNIQUE="false" FIELDS="courseid"/>
        <INDEX NAME="userid_ix" UNIQUE="false" FIELDS="userid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_aiskillnav_chunk" COMMENT="RAG chunks and embeddings">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="materialid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="chunkindex" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="chunktext" TYPE="text" NOTNULL="true"/>
        <FIELD NAME="embedding" TYPE="text"/>
        <FIELD NAME="embeddingmodel" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid_ix" UNIQUE="false" FIELDS="courseid"/>
        <INDEX NAME="materialid_ix" UNIQUE="false" FIELDS="materialid"/>
        <INDEX NAME="chunk_identity_ix" UNIQUE="false" FIELDS="materialid, chunkindex"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_aiskillnav_assessment" COMMENT="Teacher diagnostic assessments">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="assessmenttype" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pre"/>
        <FIELD NAME="focus" TYPE="char" LENGTH="255" NOTNULL="true" DEFAULT=""/>
        <FIELD NAME="difficulty" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="medium"/>
        <FIELD NAME="quizjson" TYPE="text" NOTNULL="true"/>
        <FIELD NAME="sourcemode" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="all"/>
        <FIELD NAME="materialids" TYPE="text"/>
        <FIELD NAME="visible" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid_ix" UNIQUE="false" FIELDS="courseid"/>
        <INDEX NAME="type_ix" UNIQUE="false" FIELDS="assessmenttype"/>
        <INDEX NAME="visible_ix" UNIQUE="false" FIELDS="visible"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_aiskillnav_ass_att" COMMENT="Student diagnostic assessment attempts">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="assessmentid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="score" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="maxscore" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="percentage" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="answersjson" TYPE="text"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="assessmentid_ix" UNIQUE="false" FIELDS="assessmentid"/>
        <INDEX NAME="courseid_ix" UNIQUE="false" FIELDS="courseid"/>
        <INDEX NAME="userid_ix" UNIQUE="false" FIELDS="userid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_aiskillnav_sim" COMMENT="AI simulator links generated from course materials">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="materialid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="topic" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="level" TYPE="char" LENGTH="40" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="url" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="source" TYPE="char" LENGTH="40" NOTNULL="true" DEFAULT="ai_generated" SEQUENCE="false"/>
        <FIELD NAME="materialids" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="materialtitles" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="resulttext" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="coursefk" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="course_source_idx" UNIQUE="false" FIELDS="courseid, source"/>
        <INDEX NAME="course_user_idx" UNIQUE="false" FIELDS="courseid, userid"/>
        <INDEX NAME="material_idx" UNIQUE="false" FIELDS="materialid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="local_aiskillnav_tutor_sig" COMMENT="Tutor analytics signals">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="question" TYPE="text"/>
        <FIELD NAME="sourcemode" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="none"/>
        <FIELD NAME="materials" TYPE="text"/>
        <FIELD NAME="skill" TYPE="char" LENGTH="120" NOTNULL="true" DEFAULT="General"/>
        <FIELD NAME="requesttype" TYPE="char" LENGTH="80" NOTNULL="true" DEFAULT="question"/>
        <FIELD NAME="difficulty" TYPE="char" LENGTH="40" NOTNULL="true" DEFAULT="medium"/>
        <FIELD NAME="answerpreview" TYPE="text"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="courseid_idx" UNIQUE="false" FIELDS="courseid"/>
        <INDEX NAME="userid_idx" UNIQUE="false" FIELDS="userid"/>
        <INDEX NAME="skill_idx" UNIQUE="false" FIELDS="skill"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
